// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  SELLER
  ADMIN
}

enum Category {
  ELECTRONICS
  FASHION
  HOME
  TOYS
  BOOKS
  FOOD
}

enum OrderItemStatus {
  PENDING
  DECLINE
  PROCESSING
  SHIPPED
  COMPLETED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPING
  COMPLETED
  DECLINED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentGateway {
  KHALTI
  ESEWA
  PAYPAL
  STRIPE
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  products Product[]
  cart     Cart?
  orders   Order[]

  @@map("user")
}

model Product {
  id          Int       @id @default(autoincrement())
  images      String[]  @default(["default.jpg"])
  name        String
  price       Int
  description String
  category    Category
  quantity    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       Int
  cartProducts CartItem[]
  orderItems   OrderItem[]

  @@index([name])
  @@index([category])
  @@map("product")
}

model Cart {
  id           Int        @id @default(autoincrement())
  sku          String     @default(uuid()) @db.Uuid
  userId       Int        @unique
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartProducts CartItem[]

  @@map("cart")
}

model CartItem {
  id        Int     @id @default(autoincrement())
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId    Int
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  quantity  Int     @default(1)

  @@unique([cartId, productId])
  @@map("cart_item")
}

model Order {
  id          Int         @id @default(autoincrement())
  sku         String      @unique @default(uuid()) @db.Uuid
  buyerUserId Int
  user        User        @relation(fields: [buyerUserId], references: [id], onDelete: Cascade)
  orderDate   DateTime    @default(now())
  Total       Int
  orderItems  OrderItem[]
  status      OrderStatus @default(PENDING)
  paymentId   String?     @unique @db.Uuid
  payments    Payment?    @relation(fields: [paymentId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("order")
}

model OrderItem {
  id        Int             @id @default(autoincrement())
  orderId   Int
  productId Int
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: NoAction)
  quantity  Int
  price     Int
  status    OrderItemStatus @default(PENDING)

  @@map("order_item")
}

model Payment {
  id      String         @id @default(uuid()) @db.Uuid
  geteway PaymentGateway @default(KHALTI)
  date    DateTime       @default(now())
  status  PaymentStatus  @default(PENDING)
  order   Order?

  pidx       String
  expires_at DateTime?

  @@map("payment")
}
